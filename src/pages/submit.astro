---
export const prerender = false;
import LayoutSubmit from "../layouts/LayoutSubmit.astro";
import ScrollToTop from "../components/ScrollToTop.astro";
import logoMark from "../assets/logo-vina-gallica.png";
import logoText from "../assets/vina-gallica-text.png";
import { Image } from "astro:assets";
import directus, { readItems } from "../lib/directus.ts";
import MobileMenu from "../components/MobileMenu.tsx";

const faqRaw = await directus.request(
  readItems("faq", {
    fields: ["id", { translations: ["question", "answer", "languages_code"] }],
    filter: { status: { _eq: "published" } },
    sort: ["sort"],
    deep: {
      translations: {
        _filter: { languages_code: { _eq: "en-US" } },
      },
    },
  })
);
type FaqTranslation = { question: string; answer: string };
const faqItems = (faqRaw as { translations?: FaqTranslation[] }[])
  .map((item) => item.translations?.[0])
  .filter((t): t is FaqTranslation => Boolean(t?.question));
---

<LayoutSubmit
  title="Join Vina Gallica | For Wine Businesses"
  description="Add your French wine business to Vina Gallica. Connect with enthusiasts and gain visibility across our four categories."
>
  <div class="submit-page">
    <div class="submit-topbar">
      <a href="/fr/rejoindre" class="submit-lang-link">Français</a>
      <MobileMenu client:idle />
    </div>

    <div class="submit-center">
      <a href="/" class="submit-logo" aria-label="Vina Gallica - Home Page">
        <Image
          src={logoMark}
          alt="Logo Vina Gallica"
          width={160}
          height={160}
          priority
        />
        <Image
          src={logoText}
          alt="Vina Gallica Directory"
          width={672}
          height={116}
          priority
        />
      </a>

      <h2 class="submit-intro">
        We're developing a database of French wine-related businesses. Our four categories are Adventures, Festivals, Shops, and Wineries. 
        If your business fits into at least one of these, read this page and join our community
      </h2>

      <nav class="submit-nav" aria-label="Page sections">
        <a href="#faq" class="submit-nav-link">F.A.Q.</a>
        <a href="#pricing" class="submit-nav-link">Pricing</a>
        <a href="#join" class="submit-nav-link">Join</a>
      </nav>
    </div>
  </div>

  <section id="faq" class="faq-section">
    <div class="faq-inner">
      <h2 class="faq-title">F.A.Q.</h2>
      <dl class="faq-list">
        {faqItems.map((item) => (
          <div class="faq-item">
            <dt class="faq-question">{item.question}</dt>
            <dd class="faq-answer" set:html={item.answer} />
          </div>
        ))}
      </dl>
    </div>
  </section>

  <section id="pricing" class="pricing-section">
    <div class="pricing-inner">
      <div class="pricing-header">
        <h2 class="pricing-title">Pricing</h2>
        <h3 class="pricing-subtitle">Start with a free listing and upgrade to Premium when you are ready to tell your full story</h3>
      </div>

      <div class="pricing-cards">

        <div class="pricing-card pricing-card--free">
          <div class="pricing-card-header">
            <span class="pricing-plan">Free</span>
            <span class="pricing-tagline">Ideal if you want to start your experience with us</span>
          </div>
          <ul class="pricing-features">
            <li>Listing in the <strong>Directory</strong> with your business name and category</li>
            <li>Display of <strong>wine region, address, department and region</strong></li>
            <li><strong>Website link</strong> (when applicable)</li>
            <li>Pin on the <strong>Map</strong> with a basic info panel</li>
            <li>Display of your <strong>logo and phone number</strong> in the Map panel</li>
          </ul>
          <a href="#join" class="pricing-cta pricing-cta--free">Start with Free</a>
        </div>

        <div class="pricing-card pricing-card--premium">
          <div class="pricing-card-header">
            <span class="pricing-plan">Premium</span>
            <span class="pricing-tagline">Ideal if you want to tell more about your story</span>
          </div>
          <div class="pricing-price">
            <span class="pricing-amount">€120<span class="pricing-period"> / year</span></span>
            <span class="pricing-vat">excl. VAT · billed annually</span>
            <span class="pricing-note">No automatic renewal</span>
          </div>
          <p class="pricing-description">Everything in Free, plus:</p>
          <ul class="pricing-features">
            <li><strong>Profile page</strong> with a <strong>"Read more"</strong> link from your Directory card</li>
            <li><strong>Gallery of images</strong> showcasing your place, wines and experiences</li>
            <li><strong>Marketing description</strong> of your business and wine experience</li>
            <li>Space for <strong>certifications and awards</strong> (photos, badges, labels)</li>
            <li>Extra <strong>location details</strong>: directions, nearby attractions and visitor tips</li>
            <li><strong>French translation</strong> of your listing on request — we translate your content so French-speaking visitors can discover you</li>
          </ul>
          <a href="#join" class="pricing-cta pricing-cta--premium">Go Premium for €120 / year</a>
        </div>

      </div>

      <p class="pricing-footer">For full details, please see the <a href="#faq">FAQ</a> and our <a href="/terms-of-service">Terms of Service</a> before joining Vina Gallica.</p>
    </div>
  </section>

  <section id="join" class="join-section">
    <div class="join-inner">
      <h2 class="join-title">Join</h2>
      <h3 class="join-subtitle">Create your free account and add your business to the collection</h3>

      <div id="join-success" class="join-success" role="alert" aria-live="polite" hidden>
        <p class="join-success-text">
          <span class="join-success-icon" aria-hidden="true">✓</span>
          <strong class="join-success-title">Account created!</strong>
        </p>
        <p class="join-success-body">
          Check your inbox. We've sent a confirmation email to <span id="join-success-email"></span>.
          Click the link in that email to activate your account.
        </p>
        <p class="join-success-note">Didn't receive it? Check your spam folder. The link is valid for 7 days.</p>
      </div>

      <form
        class="join-form"
        method="POST"
        action="/api/auth/register"
        id="register-form"
        novalidate
      >
        <div class="join-field">
          <label for="tax_id" class="join-label">SIREN <span aria-hidden="true">*</span></label>
          <span class="join-label-note">Your SIREN will be verified against the official French business registry.</span>
          <div class="siren-input-wrap">
            <input
              type="text"
              id="tax_id"
              name="tax_id"
              class="join-input"
              autocomplete="off"
              inputmode="numeric"
              maxlength="9"
              pattern="\d{9}"
              required
            />
            <span class="siren-status" id="siren-status" aria-live="polite"></span>
          </div>
          <span class="siren-feedback" id="siren-feedback"></span>
        </div>

        <div class="join-field">
          <label for="company_name" class="join-label">Company name <span aria-hidden="true">*</span></label>
          <span class="join-label-note">Filled in automatically after a valid SIREN is entered. You can edit it afterwards if needed.</span>
          <input
            type="text"
            id="company_name"
            name="company_name"
            class="join-input"
            autocomplete="organization"
            disabled
            required
          />
        </div>

        <div class="join-field">
          <label for="company_address" class="join-label">Company address <span aria-hidden="true">*</span></label>
          <span class="join-label-note">Filled in automatically after a valid SIREN is entered. You can edit it afterwards if needed.</span>
          <input
            type="text"
            id="company_address"
            name="company_address"
            class="join-input"
            autocomplete="street-address"
            disabled
            required
          />
        </div>

        <div class="join-form-row">
          <div class="join-field">
            <label for="first_name" class="join-label">First name <span aria-hidden="true">*</span></label>
            <span class="join-label-note">Your name as the company representative.</span>
            <input
              type="text"
              id="first_name"
              name="first_name"
              class="join-input"
              autocomplete="given-name"
              required
            />
          </div>
          <div class="join-field">
            <label for="last_name" class="join-label">Last name <span aria-hidden="true">*</span></label>
            <span class="join-label-note">Your name as the company representative.</span>
            <input
              type="text"
              id="last_name"
              name="last_name"
              class="join-input"
              autocomplete="family-name"
              required
            />
          </div>
        </div>

        <div class="join-field">
          <label for="email" class="join-label">Email address <span aria-hidden="true">*</span></label>
          <span class="join-label-note">Used as your login and for all communication from Vina Gallica.</span>
          <input
            type="email"
            id="email"
            name="email"
            class="join-input"
            autocomplete="email"
            required
          />
        </div>

        <div class="join-form-row">
          <div class="join-field">
            <label for="password" class="join-label">Password <span aria-hidden="true">*</span></label>
            <span class="join-label-note">Must contain at least 16 characters, including uppercase and lowercase letters, a number, and a special character (e.g. !@#$%).</span>
            <input
              type="password"
              id="password"
              name="password"
              class="join-input"
              autocomplete="new-password"
              minlength="16"
              required
            />
          </div>
          <div class="join-field">
            <label for="password_confirm" class="join-label">Confirm password <span aria-hidden="true">*</span></label>
            <span class="join-label-note">Re-enter your password. We recommend using <a href="https://www.dashlane.com/cs/SkV1ovFZtb4H" target="_blank" rel="noopener noreferrer">Dashlane</a> — it will help you generate a strong password and remember it. Click the link to get 6 months of Premium for free.</span>
            <input
              type="password"
              id="password_confirm"
              name="password_confirm"
              class="join-input"
              autocomplete="new-password"
              required
            />
          </div>
        </div>

        <div id="form-error" class="join-error" role="alert" hidden></div>

        <div id="turnstile-widget"></div>

        <button type="submit" class="join-submit">Create free account</button>

        <p class="join-legal">
          By registering you agree to our <a href="/terms-of-service">Terms of Service</a> and <a href="/privacy-policy">Privacy Policy</a>.
        </p>
      </form>
      </div>
    </div>
  </section>

  <ScrollToTop />
</LayoutSubmit>

<style>
  .submit-page {
    background-color: var(--color-gold);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    flex:1;
  }

  .submit-topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-inline: var(--space-sm);
    padding-block: var(--space-xs);
  }

  .submit-lang-link {
    font-family: var(--font-label);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-decoration: none;
    color: var(--color-elegant-black);
    border-bottom: 1px solid transparent;
    transition: border-color 150ms ease;
  }

  .submit-lang-link:hover {
    border-bottom-color: var(--color-elegant-black);
  }

  .submit-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
    padding-block: var(--space-xl);
  }

  .submit-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: var(--space-md);
    text-decoration: none;
    flex-wrap: wrap;
  }

  .submit-intro {
    max-width: 860px;
    text-align: center;
    font-family: var(--font-extra);
    font-size: 1.4rem;
    line-height: 1.5;
    font-weight: 500;
    text-transform: capitalize;
    color: var(--color-elegant-black);
  }

  .submit-nav {
    display: flex;
    gap: var(--space-lg);
    align-items: center;
  }

  .submit-nav-link {
    font-family: var(--font-label);
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-elegant-black);
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
    transition: border-color 150ms ease;
  }

  .submit-nav-link:hover {
    border-bottom-color: var(--color-elegant-black);
  }

  @media (max-width: 720px) {
    .submit-logo img:nth-child(2) {
      width: 90%;
      height: auto;
    }

    .submit-intro {
      font-size: 1.1rem;
    }

    .submit-nav {
      gap: var(--space-md);
    }
  }

  /* FAQ */
  .faq-section {
    background-color: var(--color-sand);
    padding-block: var(--space-xl);
    padding-inline: var(--space-lg);
  }

  .faq-inner {
    max-width: 920px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
  }

  .faq-title {
    font-family: var(--font-heading);
    font-size: 10rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-align: center;
    color: var(--color-elegant-black);
    hyphens: auto;
    text-shadow: 3px 3px 0 burlywood;
  }


 .pricing-title {
    font-family: var(--font-heading);
    font-size: 8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-align: center;
    color: var(--color-elegant-black);
    hyphens: auto;
    text-shadow: 3px 3px 1px #daa520;
  }
  .join-title {
    font-family: var(--font-heading);
    font-size: 10rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-align: center;
    color: var(--color-elegant-black);
        text-shadow: 3px 3px 0 #deb887;
  }
  @media (max-width: 820px) {
    .faq-title {
      font-size: 25vw;
    }
      .pricing-title {
        font-size: 18vw;
      }
      .join-title {
        font-size: 25vw;
      }
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .faq-item {
    padding-top: var(--space-md);
  }

  .faq-question {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    text-shadow: 2px 2px 0 var(--color-elegant-black);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: firebrick;
    margin-bottom: var(--space-sm);
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .faq-answer {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 1.1rem;
    line-height: 1.5;
    color: var(--color-elegant-black);
    hyphens: auto;
  }

  :global(.faq-answer p) {
    margin-bottom: var(--space-sm);
  }

  :global(.faq-answer p:last-child) {
    margin-bottom: 0;
  }

  :global(.faq-answer strong) {
    font-weight: 700;
    color: var(--color-elegant-black);
    font-family: var(--font-heading);
    text-transform: uppercase;
  }

  :global(.faq-answer em) {
    font-style: italic;
  }

  :global(.faq-answer ol),
  :global(.faq-answer ul) {
    padding-left: var(--space-lg);
    margin-bottom: var(--space-sm);
  }

  :global(.faq-answer ol) {
    list-style: decimal;
  }

  :global(.faq-answer ul) {
    list-style: disc;
  }

  :global(.faq-answer li) {
    margin-bottom: var(--space-xs);
  }

  :global(.faq-answer a) {
    color: var(--color-elegant-black);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 150ms ease;
  }

  :global(.faq-answer a:hover) {
    opacity: 0.65;
  }

  @media (max-width: 520px) {
    .faq-question {
      font-size: 2rem;
      text-shadow: 1.5px 1.5px 0 var(--color-elegant-black);
    }
    .submit-nav-link {
      font-size: 1.2rem;
    }
  }

  /* Pricing */
  .pricing-section {
    background-color: var(--color-gold);
    padding-block: var(--space-xl);
    padding-inline: var(--space-md);
  }

  .pricing-inner {
    max-width: 960px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .pricing-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    text-align: center;
  }

  .pricing-subtitle {
    font-family: var(--font-label);
    font-size: 1.2rem;
    line-height: 1.5;
    font-weight: 600;
    max-width: 700px;
    opacity: 0.65;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-align: center;
    color: var(--color-elegant-black);
    margin-top: calc(var(--space-sm) * -1);
    margin-left: auto;
    margin-right: auto;
  }

  .pricing-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    align-items: start;
  }

  .pricing-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding: var(--space-lg);
    border-radius: 2px;
  }
  @media (max-width: 380px) {
    .pricing-card {
      padding: var(--space-md);
    }
  }

  .pricing-card--free {
    background-color: #f0ffff;
    border: 10px solid #000000;
    color: var(--color-elegant-black);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1), 0 1px 4px rgba(0, 0, 0, 0.522) inset;}

  .pricing-card--premium {
    background-color: var(--color-elegant-black);
    border: 10px solid var(--color-gold);
    color:white;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.45), 0 2px 8px rgba(0, 0, 0, 0.3);
  }
    @media (max-width: 350px) {
    .pricing-card--free, .pricing-card--premium {
      border-width: 2px;
    }
  }

  .pricing-card-header {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .pricing-plan {
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
    @media (max-width: 340px) {
    .pricing-plan {
      font-size: 2.8rem;
    }
  }

  .pricing-card--free .pricing-plan {
    color: var(--color-elegant-black);
  }

  .pricing-card--premium .pricing-plan {
    color: var(--color-gold);
  }

  .pricing-tagline {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .pricing-price {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding-block: var(--space-sm);
    border-top: 1px solid rgba(255, 215, 0, 0.25);
    border-bottom: 1px solid rgba(255, 215, 0, 0.25);
  }

  .pricing-amount {
    font-family: var(--font-heading);
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--color-gold);
  }

  .pricing-period {
    font-size: 1.1rem;
    font-weight: 400;
  }

  .pricing-vat {
    font-family: var(--font-extra);
    font-size: 0.8rem;
    font-weight: 400;
  }

  .pricing-note {
    font-family: var(--font-extra);
    font-size: 0.85rem;
    text-transform: capitalize;
    font-weight: 400;
    margin-top: 0.25rem;
  }

  .pricing-description {
    font-family: var(--font-label);
    font-size: 0.9rem;
    line-height: 1.65;
    font-weight: 600;
    text-transform: uppercase;
  }

  .pricing-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 0;
  }

  .pricing-features li {
    font-family: var(--font-heading);
    font-size: 0.92rem;
    line-height: 1.5;
    padding-left: 1.2em;
    position: relative;
    font-weight: 300;
  }

  .pricing-features li::before {
    content: "–";
    position: absolute;
    left: 0;
    opacity: 0.6;
  }

  .pricing-card--free .pricing-features li strong {
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-elegant-black);
  }

  .pricing-card--premium .pricing-features li strong {
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-gold);
  }

  .pricing-cta {
    display: inline-block;
    margin-top: auto;
    padding: 0.75rem 1.5rem 0.5em;
    font-family: var(--font-label);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-align: center;
    border: 2px solid currentColor;
    transition: background-color 150ms ease, color 150ms ease;
  }

  .pricing-cta--free {
    color: var(--color-elegant-black);
    border-color: var(--color-elegant-black);
  }

  .pricing-cta--free:hover {
    background-color: var(--color-elegant-black);
    color: azure;
  }

  .pricing-cta--premium {
    color: var(--color-gold);
    border-color: var(--color-gold);
  }

  .pricing-cta--premium:hover {
    background-color: var(--color-gold);
    color: var(--color-elegant-black);
  }

  .pricing-footer {
    font-family: var(--font-extra);
    font-size: 0.9rem;
    text-align: center;
    color: var(--color-elegant-black);
    opacity: 0.75;
  }

  .pricing-footer a {
    color: var(--color-elegant-black);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 720px) {
    .pricing-cards {
      grid-template-columns: 1fr;
    }

  }

  /* Join / Registration */
  .join-section {
    background-color: var(--color-sand);
    padding-block: var(--space-xl);
    padding-inline: var(--space-md);
  }

  .join-inner {
    max-width: 680px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
  }

  .join-subtitle {
    font-family: var(--font-label);
    font-size: 1.2rem;
    line-height: 1.5;
    font-weight: 600;
    opacity: 0.65;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-align: center;
    color: var(--color-elegant-black);
    margin-bottom:var(--space-xl);
  }

  .join-success {
    border: 10px ridge var(--color-elegant-black);
    background-color: var(--color-gold);
    padding: var(--space-md);
    flex-direction: column;
    gap: 0.5rem;
        box-shadow: rgba(0, 0, 0, 0.2) 0px -3px 30px inset;
    animation: fadeInUp 350ms ease forwards;
  }

  .join-success:not([hidden]) {
    display: flex;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }


  .join-success-icon {
    font-size: 2rem;
    font-weight: 600;
    flex-shrink: 0;
    color:#008000;
  }

  .join-success-title {
    font-family: var(--font-label);
    font-size: 2rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-elegant-black);
  }

  .join-success-body {
    font-family: var(--font-extra);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.55;
    color: var(--color-elegant-black);
  }

  .join-success-note {
    font-family: var(--font-extra);
    font-size: 0.9rem;
    line-height: 1.5;
    font-weight: 500;
    color: firebrick;
  }
#join-success-email {
    background-color: var(--color-sand);
    padding: 4px;
    color: var(--color-elegant-black);
    font-weight: 500;
    text-transform: uppercase;
    border-bottom: 2px solid var(--color-elegant-black);
  }
  .join-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .join-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .join-field {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 0.35rem;
  }

  .join-label {
    font-family: var(--font-label);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-elegant-black);
  }

  .join-label span[aria-hidden] {
    color: firebrick;
    margin-left: 2px;
  }

  .join-label-note {
    font-family: var(--font-extra);
    font-size: 0.75rem;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    opacity: 0.65;
    display: block;
    margin-top: 2px;
  }

  .join-label-note a {
    color: var(--color-elegant-black);
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .join-label-note a:hover {
    opacity: 0.7;
  }

  .join-input {
    font-family: var(--font-extra);
    font-size: 0.95rem;
    padding: 0.6rem 0.75rem;
    border: 2px solid var(--color-elegant-black);
    background-color: white;
    color: var(--color-elegant-black);
    outline: none;
    transition: border-color 150ms ease, box-shadow 150ms ease;
    width: 100%;
    box-sizing: border-box;
    box-shadow:
    rgba(0, 0, 0, 0.4) 0px 2px 4px,
    rgba(0, 0, 0, 0.3) 0px 7px 13px -3px,
    rgba(0, 0, 0, 0.2) 0px -3px 0px inset;
  }

  .join-input:focus {
    border-color: firebrick;
    box-shadow: none;
  }

  .join-field-hint {
    font-family: var(--font-extra);
    font-size: 0.75rem;
    opacity: 0.6;
  }

  .join-error {
    background-color: #f8d7da;
    border: 1px solid #f5c6cb;
    color: #721c24;
    padding: var(--space-sm) var(--space-md);
    font-family: var(--font-extra);
    font-size: 0.9rem;
  }

  #turnstile-widget {
    align-self: center;
  }

  .join-submit {
    font-family: var(--font-label);
    font-size: 0.88rem;
    font-weight: 600;
    margin:auto;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.85rem 2rem 0.5rem;
    background-color: #31393b;
    color: var(--color-gold);
    border: 2px solid var(--color-elegant-black);
    cursor: pointer;
    transition: background-color 150ms ease, color 150ms ease;
    align-self: flex-start;
    box-shadow:
    rgba(0, 0, 0, 0.4) 0px 2px 4px,
    rgba(0, 0, 0, 0.3) 0px 7px 13px -3px,
    rgba(0, 0, 0, 0.2) 0px -3px 0px inset;
  }

  .join-submit:hover {
    background-color: azure;
    color: var(--color-elegant-black);
  }

  .join-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .join-legal {
    font-family: var(--font-extra);
    font-size: 1rem;
    margin-top: var(--space-sm);
    opacity: 0.6;
    line-height: 1.5;
    font-weight: 500;
    text-align: center;
  }

  .join-legal a {
    color: var(--color-elegant-black);
    text-underline-offset: 3px;
  }

  .join-form {
    transition: opacity 300ms ease;
  }

  .join-form.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  @media (max-width: 700px) {
    .join-form-row {
      grid-template-columns: 1fr;
    }
    .pricing-subtitle, .join-subtitle {
      font-size: 1rem;
    }
  }

  .join-input:disabled {
    background-color: #f0f0f0;
    color: #999;
    cursor: not-allowed;
    border-color: #bbb;
    box-shadow: none;
  }

  .siren-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .siren-input-wrap .join-input {
    padding-right: 2.5rem;
  }

  .siren-status {
    position: absolute;
    right: 0.75rem;
    font-size: 1.1rem;
    line-height: 1;
    pointer-events: none;
  }

  .siren-feedback {
    font-family: var(--font-extra);
    font-size: 0.8rem;
    line-height: 1.4;
    min-height: 1.2em;
  }

  .siren-feedback.is-valid {
    color: #1a6b1a;
  }

  .siren-feedback.is-invalid {
    color: firebrick;
  }
</style>

<script>
  type Turnstile = {
    render: (container: string | HTMLElement, options: Record<string, unknown>) => string;
    reset: (widgetId?: string) => void;
  };

  const SITEKEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
  let widgetId: string | undefined;

  function initTurnstile() {
    const container = document.getElementById("turnstile-widget");
    if (!container) return;
    const ts = (window as unknown as { turnstile?: Turnstile }).turnstile;
    if (!ts) return;
    container.innerHTML = "";
    widgetId = ts.render(container, {
      sitekey: SITEKEY,
      theme: "light",
      "error-callback": () => console.warn("Turnstile error"),
    });
  }

  // Wywoływany przez Turnstile po załadowaniu skryptu (onload=onTurnstileLoad w URL)
  (window as unknown as Record<string, unknown>).onTurnstileLoad = initTurnstile;

  document.addEventListener("astro:page-load", () => {
    initTurnstile();
    setupSirenValidation();
    setupForm();
  });

  let sirenValid = false;

  function setupSirenValidation() {
    const input = document.getElementById("tax_id") as HTMLInputElement | null;
    const statusEl = document.getElementById("siren-status") as HTMLElement | null;
    const feedbackEl = document.getElementById("siren-feedback") as HTMLElement | null;
    if (!input || !statusEl || !feedbackEl) return;

    sirenValid = false;
    let debounceTimer: ReturnType<typeof setTimeout>;

    function setValidating() {
      statusEl!.textContent = "⏳";
      feedbackEl!.textContent = "Verifying…";
      feedbackEl!.className = "siren-feedback";
      input!.setCustomValidity("Verifying SIREN…");
    }

    function setValid(name?: string, address?: string) {
      sirenValid = true;
      statusEl!.textContent = "✓";
      feedbackEl!.textContent = name ? `Verified: ${name}` : "SIREN verified.";
      feedbackEl!.className = "siren-feedback is-valid";
      input!.setCustomValidity("");

      const nameField = document.getElementById("company_name") as HTMLInputElement | null;
      const addressField = document.getElementById("company_address") as HTMLInputElement | null;

      if (nameField) {
        nameField.disabled = false;
        if (!nameField.value) {
          nameField.value = name ?? "";
          if (!name) nameField.placeholder = "Not found in registry — please fill in manually";
        }
      }
      if (addressField) {
        addressField.disabled = false;
        if (!addressField.value) {
          addressField.value = address ?? "";
          if (!address) addressField.placeholder = "Not found in registry — please fill in manually";
        }
      }
    }

    function lockCompanyFields() {
      const nameField = document.getElementById("company_name") as HTMLInputElement | null;
      const addressField = document.getElementById("company_address") as HTMLInputElement | null;
      if (nameField) { nameField.disabled = true; nameField.value = ""; nameField.placeholder = ""; }
      if (addressField) { addressField.disabled = true; addressField.value = ""; addressField.placeholder = ""; }
    }

    function setInvalid(msg: string) {
      sirenValid = false;
      statusEl!.textContent = "✗";
      feedbackEl!.textContent = msg;
      feedbackEl!.className = "siren-feedback is-invalid";
      input!.setCustomValidity(msg);
      lockCompanyFields();
    }

    function clear() {
      sirenValid = false;
      statusEl!.textContent = "";
      feedbackEl!.textContent = "";
      feedbackEl!.className = "siren-feedback";
      input!.setCustomValidity("");
      lockCompanyFields();
    }

    input.addEventListener("input", () => {
      clearTimeout(debounceTimer);
      const val = input.value.replace(/\D/g, "");
      if (val !== input.value) input.value = val;

      if (val.length === 0) { clear(); return; }
      if (val.length < 9) {
        clear();
        input.setCustomValidity("SIREN must be 9 digits");
        return;
      }

      setValidating();
      debounceTimer = setTimeout(async () => {
        try {
          const res = await fetch(`/api/validate-siren?siren=${val}`);
          const json = await res.json() as { valid: boolean; name?: string; address?: string; error?: string };
          if (json.valid) {
            setValid(json.name, json.address);
          } else {
            setInvalid(json.error ?? "Invalid SIREN.");
          }
        } catch {
          setInvalid("Could not verify SIREN. Please check your connection.");
        }
      }, 600);
    });
  }

  function setupForm() {
    const form = document.getElementById("register-form") as HTMLFormElement | null;
    const errorBox = document.getElementById("form-error") as HTMLElement | null;
    const successBox = document.getElementById("join-success") as HTMLElement | null;
    const successEmail = document.getElementById("join-success-email") as HTMLElement | null;
    const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    if (!form || !errorBox || !submitBtn) return;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const password = (form.querySelector("#password") as HTMLInputElement).value;
      const confirm = (form.querySelector("#password_confirm") as HTMLInputElement).value;
      const email = (form.querySelector("#email") as HTMLInputElement).value;

      if (!sirenValid) {
        errorBox.textContent = "Please enter a valid SIREN before submitting.";
        errorBox.hidden = false;
        document.getElementById("tax_id")?.focus();
        return;
      }

      if (password !== confirm) {
        errorBox.textContent = "Passwords do not match.";
        errorBox.hidden = false;
        return;
      }

      errorBox.hidden = true;
      submitBtn.disabled = true;
      submitBtn.textContent = "Creating account…";

      const res = await fetch("/api/auth/register", {
        method: "POST",
        body: new FormData(form),
      });

      const json = await res.json().catch(() => ({}));

      if (res.ok) {
        if (successEmail) successEmail.textContent = email;
        form.classList.add("is-hidden");
        setTimeout(() => {
          form.style.display = "none";
          if (successBox) {
            successBox.removeAttribute("hidden");
            successBox.scrollIntoView({ behavior: "smooth", block: "nearest" });
          }
        }, 320);
      } else {
        errorBox.textContent = (json as { error?: string }).error ?? "Registration failed. Please try again.";
        errorBox.hidden = false;
        submitBtn.disabled = false;
        submitBtn.textContent = "Create free account";
        (window as unknown as { turnstile?: Turnstile }).turnstile?.reset(widgetId);
      }
    });
  }
</script>
