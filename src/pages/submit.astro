    <div class="submit-center">
      <a href="/" class="submit-logo" aria-label="Vina Gallica - Home Page">
        <Image
          src={logoMark}
          alt="Logo Vina Gallica"
          width={160}
          height={160}
          priority
        />
        <Image
          src={logoText}
          alt="Vina Gallica Directory"
          width={672}
          height={116}
          priority
        />
      </a>

      <h2 class="submit-intro">
        If you run a business connected to the French world of wine, join us and add your company to one or more of our four categories
      </h2>

      <nav class="submit-nav" aria-label="Page sections">
        <a href="#faq" class="submit-nav-link">F.A.Q.</a>
        <a href="#pricing" class="submit-nav-link">Pricing</a>
        <a href="#join" class="submit-nav-link">Join</a>
      </nav>
    </div>
  </div>

  <section id="faq" class="faq-section">
    <div class="faq-inner">
      <Image
        src={faqHeading}
        alt="F.A.Q."
        width={358}
        height={118}
        densities={[1, 2]}
        class="faq-heading"
      />
      <dl class="faq-list">
        {faqItems.map((item) => (
          <div class="faq-item">
            <dt class="faq-question">{item.question}</dt>
            <dd class="faq-answer" set:html={item.answer} />
          </div>
        ))}
      </dl>
    </div>
  </section>
  <ScrollToTop />
</LayoutSubmit>

<style>
  .submit-page {
    background-color: var(--color-gold);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
  }

  .back-link {
    display: inline-block;
    text-decoration: none;
    align-self: flex-start;
  }
  
  .back-link-svg {
    display: block;
    height: 40px;
    width: auto;
    fill: var(--color-elegant-black);
  }

  .submit-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
    padding-block: var(--space-xl);
  }

  .submit-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: var(--space-md);
    text-decoration: none;
    flex-wrap: wrap;
  }

  .submit-intro {
    max-width: 860px;
    text-align: center;
    font-family: var(--font-label);
    font-size: 1.4rem;
    line-height: 1.5;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--color-elegant-black);
  }

  .submit-nav {
    display: flex;
    gap: var(--space-lg);
    align-items: center;
  }

  .submit-nav-link {
    font-family: var(--font-label);
    font-size: 2rem;
