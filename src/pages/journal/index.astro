---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import directus, { readItems } from "../../lib/directus.ts";
import type { ArticleCard } from "../../lib/directus.ts";
import ArticleCardComponent from "../../components/ArticleCard.astro";

Astro.response.headers.set("Cache-Control", "public, s-maxage=300, stale-while-revalidate=3600");

const directusUrl = import.meta.env.DIRECTUS_URL as string;

const articles = await directus.request(
  readItems("articles_cards_vg", {
    fields: ["id", "status", "name", "slug", "image", "preview", "date_created"],
    filter: { status: { _eq: "published" } },
    sort: ["-date_created"],
    limit: -1,
  })
) as ArticleCard[];
---

<Layout
  title="Journal | Vina Gallica"
  description="Articles, stories, and insights about French wine - regions, terroir, producers, and the culture of wine."
  headline="Articles, stories, and insights about French wine"
  headlineStyle="dark"
  canonical={new URL("/journal", Astro.site).href}
>
  <main class="journal">
    <div class="article-grid">
      {articles.map((article) => (
        <ArticleCardComponent article={article} directusUrl={directusUrl} />
      ))}
    </div>
  </main>
</Layout>

<style>
  .journal {
    flex: 1;
    padding: var(--space-xl) var(--space-lg);
    margin: 0 auto;
    width: 100%;
  }

  .article-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-lg);
  }

  @media (max-width: 700px) {
   .article-grid {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }
  }
   @media (max-width: 550px) {
    .journal {
      padding: var(--space-xl) var(--space-md);
    }}
</style>
