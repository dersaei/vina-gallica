---
export const prerender = false;
import { marked } from "marked";
import Layout from "../../layouts/Layout.astro";
import directus, { readItems } from "../../lib/directus.ts";
import type { Article } from "../../lib/directus.ts";
import "../../styles/journal-prose.css";

Astro.response.headers.set("Cache-Control", "public, s-maxage=300, stale-while-revalidate=3600");

const { slug } = Astro.params;
const directusUrl = import.meta.env.DIRECTUS_URL as string;

const results = await directus.request(
  readItems("journal_vg", {
    fields: ["id", "status", "name", "slug", "text", "main_image", "date_created"],
    filter: { slug: { _eq: slug }, status: { _eq: "published" } },
    limit: 1,
  })
) as Article[];

const article = results[0];

if (!article) {
  return Astro.redirect("/journal", 302);
}

const mainImageUrl = article.main_image
  ? `${directusUrl}/assets/${article.main_image}?width=1920&format=webp&quality=85`
  : null;

const bodyHtml = article.text ? marked(article.text) : "";

const date = new Date(article.date_created);
const formattedDate = date.toLocaleDateString("en-US", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: article.name,
  datePublished: article.date_created,
  image: mainImageUrl ?? undefined,
};
---

<Layout
  title={`${article.name} | Vina Gallica`}
  description={article.name}
  headline="French wine tells a story of place"
  headlineStyle="light"
  canonical={new URL(`/journal/${article.slug}`, Astro.site).href}
  ogType="article"
  jsonLd={jsonLd}
>
  {mainImageUrl && (
    <div class="article-hero">
      <img
        src={mainImageUrl}
        alt={article.name}
        class="article-hero-image"
        loading="eager"
        decoding="async"
      />
      <div class="article-title-wrap">
        <h1 class="article-title">{article.name}</h1>
      </div>
    </div>
  )}

  {!mainImageUrl && (
    <div class="article-title-wrap article-title-wrap--no-image">
      <h1 class="article-title">{article.name}</h1>
    </div>
  )}

  <main class="article-body">
    <time class="article-date" datetime={article.date_created}>{formattedDate}</time>
    <div class="prose" set:html={bodyHtml} />
  </main>
</Layout>

<style>
  /* Hero image — full width, no padding */
  .article-hero {
    position: relative;
    width: 100%;
  }

  .article-hero-image {
    width: 100%;
    height: 70vh;
    max-height: 600px;
    object-fit: cover;
    display: block;
  }

  /* Title — overlaps bottom edge of hero, outside overflow */
  .article-title-wrap {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%) translateY(50%);
    width: min(800px, calc(100% - 4rem));
    z-index: 10;
  }

  .article-title-wrap--no-image {
    position: static;
    transform: none;
    margin: var(--space-xl) auto var(--space-md);
  }

  .article-title {
    font-family: var(--font-heading);
    font-size: clamp(1.4rem, 3vw, 2.4rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-elegant-black);
    background-color: #fffaf3;
    border: 10px ridge wheat;
    box-shadow: rgba(0, 0, 0, 0.2) 0px -3px 30px inset;
    padding: 0.6em 1em 0.5em;
    margin: 0;
    text-align: center;
  }

  /* Body */
  .article-body {
    width: min(800px, calc(100% - 4rem));
    margin: 0 auto;
    padding-top: calc(var(--space-xl) + 1.2em); /* compensate for title overlap */
    padding-bottom: var(--space-xl);
  }

  .article-date {
    display: block;
    font-family: var(--font-extra);
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #8b7355;
    margin-bottom: var(--space-sm);
    border-bottom: 1px solid #daa520;
    padding-bottom: var(--space-sm);
  }

  /* Override prose top padding — layout handles spacing */
  .article-body .prose {
    padding: 0;
    max-width: none;
    margin-inline: 0;
  }

  @media (max-width: 600px) {
    .article-hero-image {
      height: 50vh;
    }

    .article-title-wrap {
      width: calc(100% - 2rem);
    }

    .article-body {
      width: calc(100% - 2rem);
      padding-top: calc(var(--space-xl) + 1.4em);
    }
  }
</style>
