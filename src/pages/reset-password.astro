---
export const prerender = false;
import LayoutSubmit from "../layouts/LayoutSubmit.astro";
import { Image } from "astro:assets";
import logoMark from "../assets/logo-vina-gallica.png";
import logoText from "../assets/vina-gallica-text.png";
import MobileMenu from "../components/MobileMenu.tsx";

// Przekieruj jeśli już zalogowany
const token = Astro.cookies.get("directus_access_token");
if (token) {
  return Astro.redirect("/dashboard");
}
---

<LayoutSubmit
  title="Reset Password | Vina Gallica"
  description="Request a password reset link for your Vina Gallica account."
>
  <div class="login-topbar">
    <a href="/fr/reinitialisation-de-mot-de-passe" class="login-lang-link">Français</a>
    <MobileMenu client:idle />
  </div>

  <div class="login-page">
    <a href="/" class="login-home" aria-label="Back to Vina Gallica">
      <Image src={logoMark} alt="Logo Vina Gallica" width={80} height={80} densities={[1, 2]} priority />
      <Image src={logoText} alt="Vina Gallica Directory" width={336} height={58} densities={[1, 2]} priority />
    </a>

    <div class="login-card">
      <h1 class="login-title">Reset Password</h1>
      <h2 class="login-subtitle">Request Link</h2>

      <div id="login-error" class="login-error" role="alert" hidden></div>
      <div id="login-success" class="login-success" role="alert" hidden>If this email is registered, a password reset link has been sent.</div>

      <form id="reset-form" class="login-form" novalidate>
        <input type="hidden" name="lang" value="en" />
        <div class="login-field">
          <label for="email" class="login-label">Email address</label>
          <input
            type="email"
            id="email"
            name="email"
            class="login-input"
            autocomplete="email"
            required
          />
        </div>

        <div class="login-footer" style="flex-direction: column; align-items: flex-start; gap: 1rem;">
          <button type="submit" class="login-submit" style="width: 100%;">Send reset link</button>
          <a href="/login" class="login-forgot">&larr; Back to login</a>
        </div>
      </form>
    </div>
  </div>
</LayoutSubmit>

<script>
  const form = document.getElementById("reset-form") as HTMLFormElement | null;
  const errorBox = document.getElementById("login-error") as HTMLElement | null;
  const successBox = document.getElementById("login-success") as HTMLElement | null;
  const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form || !errorBox || !successBox || !submitBtn) return;

    errorBox.hidden = true;
    successBox.hidden = true;
    submitBtn.disabled = true;
    submitBtn.textContent = "Sending…";

    const res = await fetch("/api/auth/request-password-reset", {
      method: "POST",
      body: new FormData(form),
    });

    const json = await res.json().catch(() => ({}));

    if (res.ok) {
      successBox.hidden = false;
      form.reset();
      submitBtn.textContent = "Send reset link";
      submitBtn.disabled = false;
    } else {
      errorBox.textContent = (json as { error?: string }).error ?? "Request failed. Please try again.";
      errorBox.hidden = false;
      submitBtn.disabled = false;
      submitBtn.textContent = "Send reset link";
    }
  });
</script>

<style>
  .login-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-lg) var(--space-md);
    gap: var(--space-lg);
    background-color: var(--color-gold);
  }

  .login-home {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem;
    text-decoration: none;
    opacity: 0.85;
    transition: opacity 150ms ease;
  }

  .login-home:hover { opacity: 1; }

  .login-card {
    background-color: goldenrod;
    border: 2px solid var(--color-elegant-black);
    padding: var(--space-lg) var(--space-lg);
    max-width: 440px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    box-shadow: 12px 12px 10px rgba(0, 0, 0, 0.2);
  }

  .login-title {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    text-shadow: 3px 2px 0 rgba(0, 0, 0, 0.6);
    font-weight: 700;
    -webkit-text-stroke: 0.5px var(--color-elegant-black);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color:var(--color-gold);
  }

  .login-subtitle {
    font-family: var(--font-label);
    font-size: 1.25rem;
    font-weight: 600;
    text-shadow: 1px 1px 0 rgba(255, 213, 0, 0.799);
    text-transform: capitalize;
    color: var(--color-elegant-black);
    margin-top: calc(var(--space-sm) * -1);
  }

  .login-error {
    background-color: #f8d7da;
    border: 1px solid #f5c6cb;
    color: #721c24;
    padding: 0.6rem var(--space-sm) 0.3rem;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.88rem;
  }

  .login-success {
    background-color: #d4edda;
    border: 1px solid #c3e6cb;
    color: #155724;
    padding: 0.6rem var(--space-sm) 0.3rem;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.88rem;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .login-field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .login-label {
    font-family: var(--font-hero);
    font-size: 0.88rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: capitalize;
    color: var(--color-elegant-black);
  }

  .login-input {
    font-family: var(--font-extra);
    font-size: 0.95rem;
    font-weight: 400;
    padding: 0.6rem 0.75rem;
    border: 2px solid var(--color-elegant-black);
    background-color: white;
    color: var(--color-elegant-black);
    outline: none;
    width: 100%;
    box-sizing: border-box;
    transition: border-color 150ms ease;
  }

  .login-input:focus { border-color: firebrick; }

  .login-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    margin-top: var(--space-sm);
  }

  .login-submit {
    font-family: var(--font-label);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: capitalize;
    letter-spacing: 0.12em;
    padding: 0.75rem 1.75rem 0.4rem;
    background-color: var(--color-elegant-black);
    color: var(--color-gold);
    border: 2px solid var(--color-elegant-black);
    cursor: pointer;
    transition: background-color 150ms ease, color 150ms ease;
  }

  .login-submit:hover {
    background-color: firebrick;
    color: var(--color-elegant-black);
  }

  .login-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .login-forgot {
    font-family: var(--font-extra);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-elegant-black);
    opacity: 0.75;
    text-underline-offset: 3px;
    transition: opacity 150ms ease;
  }

  .login-forgot:hover { opacity: 1; }

  .login-topbar {
    position: absolute;
    top: var(--space-md);
    left: var(--space-sm);
    right: var(--space-sm);
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-inline: var(--space-md);
    padding-block: var(--space-xs);
    z-index: 10;
  }

  .login-lang-link {
    font-family: var(--font-label);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-decoration: none;
    color: var(--color-elegant-black);
    border-bottom: 1px solid transparent;
    transition: border-color 150ms ease;
  }

  .login-lang-link:hover {
    border-bottom-color: var(--color-elegant-black);
  }
</style>
