<style is:global>
  html:has(.map-page),
  body:has(.map-page) {
    height: 100dvh;
    min-height: unset;
  }

  .map-page {
    flex: 1;
    min-height: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
</style>

<style>
  .map-directory-link {
    position: fixed;
    left: var(--space-lg);
    top: calc(var(--header-height, 0px) - 0.5em);
    z-index: 100;
    width: 120px;
    height: auto;
    opacity: 0.8;
    transition: opacity 0.3s;
  }

  .map-directory-link:hover {
    opacity: 1;
  }

  @media (max-width: 750px) {
    .map-directory-link {
      display: none;
    }
  }
</style>
