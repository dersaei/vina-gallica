---
export const prerender = false;
// map.astro stays SSR — Mapbox requires window (client:only)
import Layout from '../layouts/Layout.astro';
import MapWithPanel from '../components/MapWithPanel.tsx';
import directus, { readItems } from '../lib/directus.ts';
import type { Category, Place, WineRegion, Department, AdministrativeRegion } from '../lib/directus.ts';

Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=3600');

const [categories, places] = await Promise.all([
  directus.request(
    readItems('categories_vg', {
      fields: ['id', 'name', 'slug', 'color'],
      sort: ['name'],
    })
  ) as Promise<Category[]>,
  directus.request(
    readItems('places_vg', {
      fields: [
        'id', 'Name', 'slug', 'location', 'address', 'postal_code', 'phone', 'website', 'logo',
        { category: ['id', 'name', 'slug', 'color'] },
        { wine_region: ['id', 'region', 'color'] },
        { town: ['id', 'name', { department: ['id', 'name', 'color', { administrative_region: ['id', 'name', 'color'] }] }] },
      ] as const,
      filter: {
        status: { _eq: 'published' },
      },
      limit: -1,
    })
  ) as unknown as Promise<Place[]>,
]);

const geojson = {
  type: 'FeatureCollection' as const,
  features: places
    .filter(p => p.location !== null)
    .map(p => {
      const cat = typeof p.category === 'object' ? p.category as Category : null;
      const wr = typeof p.wine_region === 'object' && p.wine_region !== null ? p.wine_region as WineRegion : null;
      const town = typeof p.town === 'object' && p.town !== null ? p.town as { id: string; name: string; department: string | Department } : null;
      const dept = town && typeof town.department === 'object' ? town.department as Department : null;
      const adminRegion = dept && typeof dept.administrative_region === 'object' ? dept.administrative_region as AdministrativeRegion : null;
      return {
        type: 'Feature' as const,
        geometry: {
          type: 'Point' as const,
          coordinates: p.location!.coordinates,
        },
        properties: {
          id: p.id,
          name: p.Name,
          slug: p.slug,
          address: p.address ?? '',
          postalCode: p.postal_code ?? '',
          townName: town?.name ?? '',
          phone: p.phone ?? '',
          website: p.website ?? '',
          logoUrl: p.logo ? `${import.meta.env.DIRECTUS_URL}/assets/${p.logo}` : '',
          categoryId: cat?.id ?? '',
          categoryColor: cat?.color ?? '#888888',
          categoryName: cat?.name ?? '',
          wineRegionName: wr?.region ?? '',
          wineRegionColor: wr?.color ?? '',
          deptName: dept?.name ?? '',
          deptColor: dept?.color ?? '',
          adminRegionName: adminRegion?.name ?? '',
          adminRegionColor: adminRegion?.color ?? '',
        },
      };
    }),
};

const geojsonString = JSON.stringify(geojson);
const categoriesData = categories.map(c => ({
  id: c.id,
  name: c.name,
  slug: c.slug,
  color: c.color,
}));
---

<Layout
  title="French Wine Map | Vina Gallica"
  description="Explore French wine venues on an interactive map - estates, cellars, and wine experiences by region."
  headline="French Wine Map"
  headlineStyle="light"
  canonical={new URL('/map', Astro.site).href}
>
  <main class="map-page">
