    text-align: center;
  }

  .login-submit:hover {
    background-color: firebrick;
    color: var(--color-elegant-black);
  }

  .login-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .login-forgot {
    font-family: var(--font-extra);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-elegant-black);
    opacity: 0.75;
    text-underline-offset: 3px;
    transition: opacity 150ms ease;
  }

  .login-forgot:hover { opacity: 1; }

  .login-topbar {
    position: absolute;
    top: var(--space-md);
    left: var(--space-sm);
    right: var(--space-sm);
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-inline: var(--space-md);
    padding-block: var(--space-xs);
    z-index: 10;
  }

  .login-lang-link {
    font-family: var(--font-label);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-decoration: none;
    color: var(--color-elegant-black);
    border-bottom: 1px solid transparent;
    transition: border-color 150ms ease;
  }

  .login-lang-link:hover {
    border-bottom-color: var(--color-elegant-black);
  }
