---
export const prerender = false;
import LayoutSubmit from "../layouts/LayoutSubmit.astro";
import { Image } from "astro:assets";
import logoMark from "../assets/logo-vina-gallica.png";
import logoText from "../assets/vina-gallica-text.png";
import MobileMenu from "../components/MobileMenu.tsx";

const tokenParam = Astro.url.searchParams.get("token");
// If no token is provided, we can either redirect to login or show an error. 
// We'll let the user see the page and fail, or we can just hide the form if no token.
---

<LayoutSubmit
  title="Update Password | Vina Gallica"
  description="Set a new password for your Vina Gallica account."
>
  <div class="login-topbar">
    <a href={`/fr/mise-a-jour-mot-de-passe?token=${tokenParam || ''}`} class="login-lang-link">Français</a>
    <MobileMenu client:idle />
  </div>

  <div class="login-page">
    <a href="/" class="login-home" aria-label="Back to Vina Gallica">
      <Image src={logoMark} alt="Logo Vina Gallica" width={80} height={80} densities={[1, 2]} priority />
      <Image src={logoText} alt="Vina Gallica Directory" width={336} height={58} densities={[1, 2]} priority />
    </a>

    <div class="login-card">
      <h1 class="login-title">Set Password</h1>
      <h2 class="login-subtitle">Update Your Account</h2>

      <div id="login-error" class="login-error" role="alert" hidden></div>
      <div id="login-success" class="login-success" role="alert" hidden>Password updated successfully. You can now <a href="/login">log in</a>.</div>

      {tokenParam ? (
        <form id="update-form" class="login-form" novalidate>
          <input type="hidden" name="token" value={tokenParam} />
          
          <div class="login-field">
            <label for="password" class="login-label">New Password</label>
            <input
              type="password"
              id="password"
              name="password"
              class="login-input"
              autocomplete="new-password"
              minlength="16"
              required
            />
          </div>

          <div class="login-field">
            <label for="password_confirm" class="login-label">Confirm Password</label>
            <input
              type="password"
              id="password_confirm"
              name="password_confirm"
              class="login-input"
              autocomplete="new-password"
              minlength="16"
              required
            />
          </div>

          <div class="login-footer" style="flex-direction: column; align-items: flex-start; gap: 1rem;">
            <button type="submit" class="login-submit" style="width: 100%;">Update password</button>
          </div>
        </form>
      ) : (
        <>
          <div class="login-error" style="display: block;">Invalid or missing reset token. Please request a new password reset link.</div>
          <a href="/reset-password" class="login-submit" style="text-align: center; text-decoration: none;">Request Link</a>
        </>
      )}
    </div>
  </div>
</LayoutSubmit>

<script>
  const form = document.getElementById("update-form") as HTMLFormElement | null;
  const errorBox = document.getElementById("login-error") as HTMLElement | null;
  const successBox = document.getElementById("login-success") as HTMLElement | null;
  const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form || !errorBox || !successBox || !submitBtn) return;

    const pw = (document.getElementById("password") as HTMLInputElement).value;
    const cpw = (document.getElementById("password_confirm") as HTMLInputElement).value;

    if (pw !== cpw) {
      errorBox.textContent = "Passwords do not match.";
      errorBox.hidden = false;
      return;
    }

    if (pw.length < 8) {
      errorBox.textContent = "Password must be at least 8 characters.";
      errorBox.hidden = false;
      return;
    }

    errorBox.hidden = true;
    successBox.hidden = true;
    submitBtn.disabled = true;
    submitBtn.textContent = "Updating…";

    const res = await fetch("/api/auth/reset-password", {
      method: "POST",
      body: new FormData(form),
    });

    const json = await res.json().catch(() => ({}));

    if (res.ok) {
      successBox.hidden = false;
      form.style.display = "none";
    } else {
      errorBox.textContent = (json as { error?: string }).error ?? "Failed to update password. Token might be expired.";
      errorBox.hidden = false;
      submitBtn.disabled = false;
      submitBtn.textContent = "Update password";
    }
  });
</script>

