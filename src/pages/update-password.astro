  }

  .login-input {
    font-family: var(--font-extra);
    font-size: 0.95rem;
    font-weight: 400;
    padding: 0.6rem 0.75rem;
    border: 2px solid var(--color-elegant-black);
    background-color: white;
    color: var(--color-elegant-black);
    outline: none;
    width: 100%;
