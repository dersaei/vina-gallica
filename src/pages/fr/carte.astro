</Layout>

<style is:global>
  body:has(.map-page) {
    height: 100dvh !important;
  }

  @media (max-width: 768px) {
    html:has(.map-page),
    body:has(.map-page) {
      height: 100dvh !important;
    }
  }

  .map-page {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }
</style>

<style>
  .carte-annuaire-link {
    position: fixed;
    left: var(--space-lg);
    top: calc(var(--header-height, 0px) - 0.5em);
    z-index: 100;
    width: 120px;
    height: auto;
    opacity: 0.8;
    transition: opacity 0.3s;
  }

  .carte-annuaire-link:hover {
    opacity: 1;
  }

  @media (max-width: 750px) {
    .carte-annuaire-link {
      display: none;
    }
  }
</style>
