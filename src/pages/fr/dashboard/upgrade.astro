---
export const prerender = false;
import LayoutDashboard from "../../../layouts/LayoutDashboard.astro";
---

<LayoutDashboard title="Abonnement | Vina Gallica" active="upgrade" lang="fr">
  <div style="max-width:860px;margin:auto;text-align:center;padding:var(--space-xl) 0;">
    <h1 style="font-family:var(--font-heading);font-size:clamp(1.8rem,4vw,2.5rem);font-weight:700;text-transform:uppercase;letter-spacing:0.04em;color:var(--color-elegant-black);    text-shadow: 2px 2px 0 goldenrod, -1px 1px 0 gold, 1px -1px 0 goldenrod, -1px -1px 0 #fff;">Abonnement Premium</h1>
    <p style="font-family:var(--font-extra);margin-top:var(--space-md);color:var(--color-elegant-black);">Bientôt disponible.</p>
  </div>
</LayoutDashboard>
