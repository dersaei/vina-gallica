---
export const prerender = false;
import LayoutDashboard from "../../../layouts/LayoutDashboard.astro";
import ListingsManager from "../../../components/ListingsManager";
const accessToken = Astro.cookies.get("directus_access_token")?.value;
const DIRECTUS_URL = import.meta.env.DIRECTUS_URL;
const DIRECTUS_SERVICE_TOKEN = import.meta.env.DIRECTUS_SERVICE_TOKEN ?? import.meta.env.DIRECTUS_STATIC_TOKEN;

let plan: "free" | "premium" = "free";
if (accessToken) {
  try {
    const res = await fetch(`${DIRECTUS_URL}/users/me?fields=plan`, {
      headers: { Authorization: `Bearer ${accessToken}` },
    });
    if (res.ok) {
      const body = await res.json() as { data: { plan?: string } };
      if (body.data.plan === "premium") plan = "premium";
    }
  } catch { /* token expiré */ }
}

const headers = { Authorization: `Bearer ${DIRECTUS_SERVICE_TOKEN}` };

const [wrRes, catRes] = await Promise.all([
  fetch(`${DIRECTUS_URL}/items/wine_regions?fields=id,region&sort[]=region`, { headers }),
  fetch(`${DIRECTUS_URL}/items/categories_vg?fields=id,name,name_fr&sort[]=name`, { headers }),
]);

const wineRegions: { id: string; region: string }[] = wrRes.ok
  ? ((await wrRes.json()) as { data: { id: string; region: string }[] }).data
  : [];
const categories: { id: string; name: string; name_fr: string | null }[] = catRes.ok
  ? ((await catRes.json()) as { data: { id: string; name: string; name_fr?: string | null }[] }).data
    .map(c => ({ ...c, name_fr: c.name_fr ?? null }))
  : [];

const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN;
---

<LayoutDashboard title="Soumettre | Vina Gallica" active="submit" lang="fr">
  <ListingsManager
    client:load
    lang="fr"
    plan={plan}
    wineRegions={wineRegions}
    categories={categories}
    mapboxToken={mapboxToken}
  />
</LayoutDashboard>
