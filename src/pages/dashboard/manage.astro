---
export const prerender = false;
import LayoutDashboard from "../../layouts/LayoutDashboard.astro";
---

<LayoutDashboard title="Manage | Vina Gallica" active="manage">
  <h1 class="dash-title">Manage</h1>
  <p class="dash-placeholder-text">Profile editing is coming soon.</p>
</LayoutDashboard>

<style>
  .dash-title {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-elegant-black);
  }

  .dash-placeholder-text {
    font-family: var(--font-extra);
    font-size: 0.92rem;
    color: var(--color-elegant-black);
    opacity: 0.55;
    line-height: 1.6;
  }
</style>
