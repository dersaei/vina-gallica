---
export const prerender = false;
import LayoutDashboard from "../../layouts/LayoutDashboard.astro";

type User = {
  id: string;
  first_name: string;
  last_name: string;
  email: string;
  company_name?: string;
  tax_id?: string;
  company_address?: string;
  plan?: string;
};

const accessToken = Astro.cookies.get("directus_access_token")?.value;
const DIRECTUS_URL = import.meta.env.DIRECTUS_URL;

let user: User | null = null;

if (accessToken) {
  try {
    const res = await fetch(
      `${DIRECTUS_URL}/users/me?fields=id,first_name,last_name,email,company_name,tax_id,company_address,plan`,
      { headers: { Authorization: `Bearer ${accessToken}` } }
    );
    if (res.ok) {
      const body = await res.json() as { data: User };
      user = body.data;
    }
  } catch {
    // token wygasł — middleware przekieruje przy odświeżeniu
  }
}

const u = user;
---

<LayoutDashboard title="Details | Vina Gallica" active="details">
  {u && (
    <div class="details">
      <h1 class="details-title">Account details</h1>

      <div class="details-list">
        <div class="details-field">
          <span class="details-label">First name</span>
          <span class="details-value">{u.first_name}</span>
        </div>
        <div class="details-field">
          <span class="details-label">Last name</span>
          <span class="details-value">{u.last_name}</span>
        </div>
        <div class="details-field">
          <span class="details-label">Email address</span>
          <span class="details-value">{u.email}</span>
        </div>
        <div class="details-field">
          <span class="details-label">Company name</span>
          <span class="details-value">{u.company_name ?? <em class="details-empty">Not provided</em>}</span>
        </div>
        <div class="details-field">
          <span class="details-label">Tax ID</span>
          <span class="details-value">{u.tax_id ?? <em class="details-empty">Not provided</em>}</span>
        </div>
        <div class="details-field">
          <span class="details-label">Company address</span>
          <span class="details-value">{u.company_address ?? <em class="details-empty">Not provided</em>}</span>
        </div>
        <div class="details-field">
          <span class="details-label">Plan</span>
          <span class="details-value">
            <span class={`details-plan details-plan--${u.plan ?? "free"}`}>
              {u.plan === "premium" ? "Premium" : "Free"}
            </span>
          </span>
        </div>
      </div>
    </div>
  )}
</LayoutDashboard>

<style>
  .details {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    max-width: 860px;
    margin: auto;
  }

  .details-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    text-shadow: 2px 2px 0 goldenrod, -1px 1px 0 gold, 1px -1px 0 goldenrod, -1px -1px 0 #fff;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-elegant-black);
  }

  .details-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .details-field {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-direction: row;
    gap: 0.25rem;
  }

  .details-label {
    font-family: var(--font-label);
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-elegant-black);
  }

  .details-value {
    font-family: var(--font-extra);
    font-size: 1.05rem;
    color: var(--color-elegant-black);
    line-height: 1.3;
    background-color: beige;
    padding: 0.35rem 0.75rem;
    border-style: solid;
    border-width: 2px;
    border-bottom-left-radius: 15px 255px;
    border-bottom-right-radius: 225px 15px;
    border-top-left-radius: 255px 15px;
    border-top-right-radius: 15px 225px;
  }

  .details-empty {
    font-style: italic;
  }

  .details-plan {
    display: inline-block;
    font-family: var(--font-label);
    font-size: 1rem;
    padding-top: 0.4em;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .details-plan--free {
    color: #008000;
  }

  .details-plan--premium {
    color: #b22222;
  }
    @media (max-width: 700px) {
    .details-field {
      flex-direction: column;
      align-items: flex-start;
    }

    .details-value {
      width: 100%;
    }
  }
</style>
