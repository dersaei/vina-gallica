---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Vina Gallica | Discover French Wine Culture">
  <main class="hero">
    <div class="hero-block hero-directory">
      <div class="hero-content">
        <span class="hero-label">Gateway</span>
        <h2>Directory</h2>
        <p>
          A comprehensive directory of French wineries, wine festivals,
          wine shops, and tasting experiences across the country.
          Filter by wine region or search by town to find exactly
          what you're looking for.
        </p>
        <a href="/directory" class="hero-cta">Browse the Directory</a>
      </div>
    </div>

    <div class="hero-block hero-map">
      <div class="hero-content">
        <span class="hero-label">Journey</span>
        <h2>Map</h2>
        <p>
          See France's wine landscape on an interactive map.
          Filter by region, category, or town to locate wineries,
          festivals, and experiences — whether you're planning
          a trip or exploring from home.
        </p>
        <a href="/map" class="hero-cta">Open the Map</a>
      </div>
    </div>
  </main>
</Layout>

<style>
  .hero {
    display: flex;
    flex: 1;
    min-height: 0;
  }

  .hero-block {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-lg);
    position: relative;
    overflow: hidden;
  }

  /* Directory — warm, earthy wine tones */
  .hero-directory {
    background-color: #b22222;
      box-shadow: rgba(0, 0, 0, 0.2) 0px -3px 310px inset;

  }



  /* Map — deep navy, cartographic feel */
  .hero-map {
    background-color: #31393B;
      box-shadow: rgba(145, 139, 139, 0.2) 0px -3px 310px inset;

  }

 

  /* Content */
  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 440px;
  }

  .hero-label {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    margin-bottom: var(--space-md);
    font-family: var(--font-label);
  }



  /* Headings — light on dark backgrounds */
  h2 {
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: var(--space-md);
    letter-spacing: -0.01em;
        color: #faf6f0;
font-family: var(--font-heading);
text-shadow: 4px 4px 2px black;
  }



  /* Body text */
  p {
    font-weight: 500;
    font-size: 1rem;
    line-height: 1.75;
    margin-bottom: var(--space-lg);
    font-family: var(--font-hero);
    text-shadow: 1px 2px 2px black;
  }

  .hero-directory span, .hero-directory p {
    color: beige;
  } 
  .hero-map span, .hero-map p {
    color: #f5deb3;
  }


  /* CTA buttons */
  .hero-cta {
    display: block;
    width: fit-content;
    position: relative;
    font-weight: 400;
    font-size: 0.8rem;
    line-height: 1;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.95em 1.8em 0.75em;
    border-radius: 2px;
    font-family: var(--font-heading);
    background-color: transparent;
    color: #e8eaed;
    border: 1px solid rgba(232, 234, 237, 0.25);
    transition: all 0.4s ease;
  }


  .hero-cta:hover {
    background-color: rgba(255, 255, 255, 0.05);
    border-color: rgba(232, 234, 237, 0.5);
    transform: translateY(-1px);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hero {
      flex-direction: column;
      flex: none;
    }

    .hero-block {
      min-height: 50vh;
      padding: var(--space-xl) var(--space-lg);
    }

   
  }
</style>