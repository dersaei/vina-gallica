    <div class="filter-by-wrap">
      <RegionFilter
        client:load
        wineRegions={wineRegions}
        adminRegions={adminRegions}
        departments={departments}
        towns={towns}
      />
    </div>

    <div class="filters-bar">
      <div class="filter-group">
        <h2 class="filter-label">Categories</h2>
        <div class="filter-buttons" id="category-filters">
          <button
            class="filter-btn active"
            data-filter="all"
            style="--btn-color: var(--color-elegant-black)"
          >
            All
          </button>
          {categories.map((cat) => (
            <button
              class="filter-btn"
              data-filter={cat.slug}
              style={`--btn-color: ${cat.color}`}
            >
              {cat.name}
            </button>
          ))}
        </div>
      </div>

    </div>


    <div class="places-grid" id="places-grid">
      {places.map((place) => (
        <PlaceCard place={place} />
      ))}
    </div>
  </main>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    const catButtons = document.querySelectorAll<HTMLButtonElement>('#category-filters .filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('.place-card');

    let activeCategory = 'all';
    let activeWineRegion: string | null = null;
    let activeAdminRegion: string | null = null;
    let activeDept: string | null = null;
    let activeTown: string | null = null;

    function applyFilters() {
      cards.forEach((card) => {
        const matchCat = activeCategory === 'all' || card.dataset.category === activeCategory;
        const matchWine = !activeWineRegion || card.dataset.wineRegion === activeWineRegion;
        const matchAdmin = !activeAdminRegion || card.dataset.adminRegion === activeAdminRegion;
        const matchDept = !activeDept || card.dataset.dept === activeDept;
        const matchTown = !activeTown || card.dataset.town === activeTown;
        card.style.display = (matchCat && matchWine && matchAdmin && matchDept && matchTown) ? '' : 'none';
      });
    }

    catButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        activeCategory = btn.dataset.filter ?? 'all';
        catButtons.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        applyFilters();
      });
    });

    // Region filter events from RegionFilter React component
    document.addEventListener('region-filter', (e) => {
      const { wine, admin, dept, town } = (e as CustomEvent).detail;
      activeWineRegion = wine;
      activeAdminRegion = admin;
      activeDept = dept;
      activeTown = town;
      applyFilters();
    });
  });
</script>

<style>
  .directory {
    flex: 1;
    display: flex;
    flex-direction: column;
    background-color: var(--color-sand);
    position: relative;
  }

  #flower {
    width: 25px;
    height: auto;
    display: block;
    position: relative;
    margin: 6vh auto 0;
  }

  .filters-bar {
    padding: var(--space-md) var(--space-lg);
  }

  .filter-group {
    display: flex;
      flex-direction: column;
      align-items: center;
  }

  .filter-label {
    font-family: var(--font-heading);
    font-size:clamp(2.1rem, 4vw, 3rem);
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--color-elegant-black);
    text-shadow: 1px 2px 4px #deb887;
    flex-shrink: 0;
  }


  .filter-buttons {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    align-items: stretch;
    gap: var(--space-sm);
  }

  .filter-btn {
    font-family: var(--font-label);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.6em 1em 0.2em;
    border-radius: 2px;
    border: 1px solid color-mix(in srgb, var(--btn-color) 40%, transparent);
    background-color: antiquewhite;
    color: var(--btn-color);
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .filter-btn:hover {
    background-color: color-mix(in srgb, var(--btn-color) 10%, transparent);
    border-color: color-mix(in srgb, var(--btn-color) 70%, transparent);
  }

  .filter-btn.active {
    background-color: var(--btn-color);
    border-color: var(--btn-color);
    color: #fff;
  }

.places-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-md);
    padding: var(--space-lg);
  }
.filter-by-wrap {
    padding: 0 var(--space-lg);
    position: relative;
  }

  .directory-map-link {
    position: absolute;
    left: var(--space-lg);
    top: -0.5em;
    z-index: 100;
    width: 120px;
    height: auto;
    opacity: 0.8;
    transition: opacity 0.3s;
  }

  .directory-map-link:hover {
    opacity: 1;
  }

  @media (max-width: 750px) {
    .directory-map-link {
      display: none;
    }
  }
  @media (max-width: 450px) {
    .places-grid {
      padding: var(--space-md);
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 365px) {
    .filter-by-wrap {
      padding: 0 var(--space-sm);
    }
  }

</style>
