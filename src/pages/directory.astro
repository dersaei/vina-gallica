---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import directus, { readItems } from '../lib/directus.ts';
import type { Category, Place } from '../lib/directus.ts';
import PlaceCard from '../components/PlaceCard.astro';
import RegionFilter from '../components/RegionFilter.tsx';

Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=3600');

interface AdminRegion { id: string; name: string; slug: string; color: string; }
interface Department { id: string; name: string; slug: string; color: string; administrative_region: string; }
interface TownItem { id: string; name: string; slug: string; department: string; }

const [categories, wineRegions, adminRegions, departments, towns, places] = await Promise.all([
  directus.request(
    readItems('categories_vg', {
      fields: ['id', 'name', 'slug', 'color'],
      sort: ['name'],
    })
  ) as Promise<Category[]>,
  directus.request(readItems('wine_regions', { fields: ['id', 'region', 'slug', 'color'], sort: ['region'] })) as unknown as Promise<{ id: string; region: string; slug: string; color: string }[]>,
  directus.request(readItems('administrative_regions', { fields: ['id', 'name', 'slug', 'color'], sort: ['name'] })) as unknown as Promise<AdminRegion[]>,
  directus.request(readItems('departments', { fields: ['id', 'name', 'slug', 'color', 'administrative_region'], sort: ['name'] })) as unknown as Promise<Department[]>,
  directus.request(readItems('towns', { fields: ['id', 'name', 'slug', 'department'], sort: ['name'] })) as unknown as Promise<TownItem[]>,
  directus.request(
    readItems('places_vg', {
      fields: [
        'id', 'Name', 'slug', 'status',
        'address', 'postal_code', 'website', 'phone', 'logo',
        { category: ['id', 'name', 'slug', 'color'] },
        { wine_region: ['region', 'slug', 'color'] },
        { town: ['id', 'name', 'slug', { department: ['id', 'name', 'slug', 'color', { administrative_region: ['id', 'name', 'slug', 'color'] }] }] },
      ] as const,
      filter: { status: { _eq: 'published' } },
      sort: ['Name'],
      limit: -1,
    })
  ) as unknown as Promise<Place[]>,
]);
---


