---
import { marked } from 'marked';
import Layout from '../layouts/Layout.astro';
import directus, { readSingleton } from '../lib/directus.ts';
import type { PrivacyPolicy } from '../lib/directus.ts';

const data = await directus.request(
  readSingleton('privacy_policy_vg', { fields: ['id', 'Text'] })
) as PrivacyPolicy;

const htmlContent = marked(data.Text);
---

<Layout
  title="Privacy Policy | Vina Gallica"
  description="Vina Gallica privacy policy — how we collect, use, and protect your data."
  headline="Privacy Policy"
  headlineStyle="dark"
  canonical={new URL('/privacy-policy', Astro.site).href}
  noindex={true}
>
  <main class="privacy-content">
    <div class="prose" set:html={htmlContent} />
  </main>
</Layout>

<style>
  .privacy-content {
    flex: 1;
    padding: 5rem 1.5rem 2rem;
    display: flex;
    justify-content: center;
  }

  .prose {
    width: 100%;
    max-width: 760px;
    color: var(--color-elegant-black);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    line-height: 1.75;
  }

  .prose :global(h1) {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 400;
    margin-bottom: 0.25em;
    margin-top: 0;
  }

  .prose :global(h2) {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 400;
    margin-top: 2.5rem;
    margin-bottom: 0.5rem;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid #daa520;
  }

  .prose :global(h3) {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 1.75rem;
    margin-bottom: 0.4rem;
    color: #b22222;
  }

  .prose :global(p) {
    margin-bottom: 1rem;
  }

  .prose :global(strong) {
    font-weight: 700;
  }

  .prose :global(a) {
    color: #b22222;
    text-underline-offset: 3px;
  }

  .prose :global(a:hover) {
    color: #daa520;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .prose :global(li) {
    margin-bottom: 0.3rem;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
    margin: 1.5rem 0;
    overflow-x: auto;
    display: block;
  }

  .prose :global(thead) {
    background-color: #b22222;
    color: var(--color-sand);
    border: 2px ridge black
  }

  .prose :global(th) {
    padding: 0.5rem 0.75rem 0.2rem;
    text-align: left;
    font-family: var(--font-label);
    font-weight: 600;
    white-space: nowrap;
    border: 1px ridge black;
  }

  .prose :global(td) {
    padding: 0.45rem 0.75rem;
    border-bottom: 1px ridge #ddd;
    vertical-align: top;
  }

  

  .prose :global(tbody tr:nth-child(even)) {
    background-color: rgba(245, 222, 179, 0.3);
  }

  .prose :global(code) {
    font-family: monospace;
    font-size: 0.88em;
    background-color: rgba(0, 0, 0, 0.06);
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid #daa520;
    margin: 2.5rem 0;
  }

  @media (max-width: 768px) {
    .privacy-content {
      padding: 4rem 1rem 3rem;
    }

    .prose :global(h1) {
      font-size: 1.3rem;
    }

    .prose :global(h2) {
      font-size: 1.05rem;
    }
  }
</style>
