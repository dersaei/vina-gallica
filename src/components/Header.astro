---
import logoMark from "../assets/logo-vina-gallica.png";
import logoTextEn from "../assets/vina-gallica-text.png";
import logoTextFr from "../assets/logo-vina-gallica-fr.png";
import { Image } from "astro:assets";
import MobileMenu from "./MobileMenu.tsx";

interface Props {
  lang?: "en" | "fr";
}
const { lang = "en" } = Astro.props;
const logoText = lang === "fr" ? logoTextFr : logoTextEn;
const logoTextWidth = lang === "fr" ? 340 : 336;
const logoTextHeight = lang === "fr" ? 58 : 58;
const homeHref = lang === "fr" ? "/fr" : "/";
---

<header>
  <div class="header-inner">
    <a href={homeHref} aria-label="Vina Gallica - Home Page" class="logo-link">
      <Image
        src={logoMark}
        alt="Logo Vina Gallica"
        width={50}
        height={50}
        densities={[1, 2]}
        priority
      />
      <Image
        src={logoText}
        alt="Vina Gallica Directory"
        width={logoTextWidth}
        height={logoTextHeight}
        densities={[1, 2]}
        priority
      />
    </a>
    <div class="header-right">
    </div>
    <MobileMenu client:load />
  </div>
</header>

<script>
  function setHeaderHeight() {
    const header = document.querySelector("header");
    if (header) {
      document.documentElement.style.setProperty(
        "--header-height",
        header.offsetHeight + "px"
      );
    }
  }
  setHeaderHeight();
  window.addEventListener("resize", setHeaderHeight, { passive: true });
  document.addEventListener("astro:page-load", setHeaderHeight);
</script>

<style>
  header {
    background-color: var(--color-gold);
    position: sticky;
    top: 0;
    border-bottom: 1px solid var(--color-elegant-black);
    z-index: 200;
    view-transition-name: site-header;
  }

  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding-inline: var(--space-md);
    padding-block: var(--space-sm);
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
  }

  .header-right {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: var(--space-sm);
    position: relative;
  }
  

  @media (max-width: 820px) {
    .header-right {
      display: none;
    }
  }

  @media (max-width: 490px){
    .logo-link {
  scale: calc(0.8);
  margin-left: -10vw;
}
  }
  @media (max-width:406px){
    .logo-link img:nth-child(even) {
      display: none;
    }
    .logo-link {
            scale: calc(1);
margin-left: 0;
   }
     
  }
</style>
