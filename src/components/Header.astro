---
import logoMark from "../assets/logo-vina-gallica.png";
import logoText from "../assets/vina-gallica-text.png";
import img001 from "../assets/001.png";
import img002 from "../assets/002.png";
import { Image } from "astro:assets";
import MobileMenu from "./MobileMenu.tsx";
---

<header>
  <div class="header-inner">
    <a href="/" aria-label="Vina Gallica - Home Page" class="logo-link">
      <Image
        src={logoMark}
        alt="Logo Vina Gallica"
        width={50}
        height={50}
        densities={[1, 2]}
        loading="eager"
        fetchpriority="high"
      />
      <Image
        src={logoText}
        alt="Vina Gallica Directory"
        width={336}
        height={58}
        densities={[1, 2]}
        loading="eager"
        fetchpriority="high"
      />
    </a>
    <div class="header-right">
          <a href="/journal" aria-label="Vina Gallica - Journal" class="logo-link">
      <Image
        src={img001}
        alt="Journal Vina Gallica"
        width={168}
        height={30}
        densities={[1, 2]}
        loading="eager"
        fetchpriority="high"
      />
      </a>
      <Image
        src={img002}
        alt="About Vina Gallica"
        width={126}
        height={30}
        densities={[1, 2]}
        loading="eager"
        fetchpriority="high"
      />
    </div>
    <MobileMenu client:load />
  </div>
</header>

<script>
  function setHeaderHeight() {
    const header = document.querySelector("header");
    if (header) {
      document.documentElement.style.setProperty(
        "--header-height",
        header.offsetHeight + "px"
      );
    }
  }
  setHeaderHeight();
  window.addEventListener("resize", setHeaderHeight, { passive: true });
  document.addEventListener("astro:page-load", setHeaderHeight);
</script>

<style>
  header {
    background-color: var(--color-gold);
    position: sticky;
    top: 0;
    border-bottom: 1px solid var(--color-elegant-black);
    z-index: 200;
    view-transition-name: site-header;
  }

  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding-inline: var(--space-md);
    padding-block: var(--space-sm);
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
  }

  .header-right {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: var(--space-sm);
    position: relative;
  }
  

  @media (max-width: 820px) {
    .header-right {
      display: none;
    }
  }

  @media (max-width: 490px){
    .logo-link {
  scale: calc(0.8);
  margin-left: -10vw;
}
  }
  @media (max-width:406px){
    .logo-link img:nth-child(even) {
      display: none;
    }
    .logo-link {
            scale: calc(1);
margin-left: 0;
   }
     
  }
</style>
