---
interface Props {
  lang?: "en" | "fr";
}
const { lang = "en" } = Astro.props;
const year = new Date().getFullYear();
const submitHref = lang === "fr" ? "/fr/submit" : "/submit";
const submitLabel =
  lang === "fr" ? "Inscrivez-vous sur Vina Gallica" : "Get listed on Vina Gallica";
---

<footer>
  <div class="footer-inner">
    <p><a href={submitHref} class="footer-link">{submitLabel}&nbsp;{year}</a></p>
  </div>
</footer>

<style>
  footer {
    background-color: var(--color-gold);
    position: sticky;
    bottom: 0;
    border-top: 1px solid var(--color-elegant-black);
    z-index: 200;
    view-transition-name: site-footer;
  }

  .footer-inner {
    display: flex;
    justify-content: center;
    align-items: baseline;
    position: relative;
    padding-inline: var(--space-lg);
    padding-block: var(--space-xs);
  }

  footer p {
    color: var(--color-elegant-black);
    font-size: 0.75rem;
    margin: 0;
    letter-spacing: 0.03em;
        text-align: center;

  }

  .footer-link {
    color: var(--color-elegant-black);
    font-size: 0.75rem;
    font-weight: 300;
    letter-spacing: 0.03em;
    font-family: var(--font-heading);
    text-decoration: none;
  }

  .footer-link:hover {
    color: #b22222;
  }

</style>