<style>
  .journal-badges {
    position: fixed;
    left: var(--space-lg);
    top: calc(var(--header-height, 0px) - 0.5em);
    z-index: 100;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .journal-badges--fixed {
    position: fixed;
    top: auto;
    /* align with page-headline-wrap height:0 band — sits just below header */
    bottom: auto;
  }

  .journal-badges a {
    display: block;
    line-height: 0;
  }
  #directory, #map {
    opacity: 0.8;
    transition: opacity 0.3s;
}
  #directory:hover, #map:hover {
    opacity: 1;
  }

  .journal-badges svg {
    width: 120px;
    height: auto;
    display: block;
  }

  @media (max-width: 820px) {
    .journal-badges {
      display: none;
    }
  }
</style>
