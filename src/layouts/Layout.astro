---
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import "../styles/reset.css";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollToTop from "../components/ScrollToTop.astro";
import AgeGate from "../components/AgeGate";

interface LayoutProps {
  title: string;
  description: string;
  headline: string;
  headlineStyle?: "light" | "dark";
  lang?: "en" | "fr";
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: "website" | "article";
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: object | object[];
}

interface Props extends LayoutProps {
  frontmatter?: LayoutProps;
}

const props = Astro.props.frontmatter ?? Astro.props;

const {
  title,
  description,
  headline,
  headlineStyle = "dark",
  lang = "en",
  canonical = new URL(Astro.url.pathname, Astro.site).href,
  ogTitle = title,
  ogDescription = description,
  ogType = "website",
  ogImage,
  noindex = false,
  jsonLd,
} = props;

const alternateLang = lang === "en" ? "fr" : "en";
const alternateHref =
  lang === "en"
    ? new URL("/fr" + (Astro.url.pathname === "/" ? "" : Astro.url.pathname), Astro.site).href
    : new URL(Astro.url.pathname.replace(/^\/fr/, "") || "/", Astro.site).href;
const ogLocale = lang === "fr" ? "fr_FR" : "en_US";
---

<!doctype html>
<html lang={lang === "fr" ? "fr-FR" : "en-US"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocale} />
    <link rel="alternate" hreflang={lang} href={canonical} />
    <link rel="alternate" hreflang={alternateLang} href={alternateHref} />
    <link rel="alternate" hreflang="x-default" href={lang === "en" ? canonical : alternateHref} />
    <meta property="og:site_name" content="Vina Gallica" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    {noindex && <meta name="robots" content="noindex, follow" />}
    {jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <Font cssVariable="--font-heading" preload />
    <Font cssVariable="--font-label" />
    <Font cssVariable="--font-hero" preload />
    <Font cssVariable="--font-extra" />
    <ClientRouter />
  </head>
  <body>
    <AgeGate client:load />
    <Header lang={lang} />
    <div class:list={["page-headline-wrap", headlineStyle]}>
      <h1 class="page-headline">{headline}</h1>
    </div>
    <slot />
    <Footer lang={lang} />
    <ScrollToTop />
  </body>
</html>

<style is:global>
  html {
    min-height: 100%;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .page-headline-wrap {
    display: flex;
    justify-content: center;
    position: sticky;
    top: var(--header-height, 0px);
    z-index: 11;
    height: 0;
  }

  .page-headline {
    position: absolute;
    top: 0;
    white-space: nowrap;
    padding: 0.25em 1em 0.05em;
    text-transform: uppercase;
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 400;
    box-shadow: rgba(0, 0, 0, 0.2) 0px -3px 10px inset;
    view-transition-name: hero-headline;
  }

  .page-headline-wrap.dark .page-headline {
    background-color: #f5deb3;
    color: var(--color-elegant-black);
  }

  .page-headline-wrap.light .page-headline {
    background-color: #b22222;
    color: #f5deb3;
  }

  @media (max-width: 540px) {
    .page-headline {
      width: 100%;
      text-align: center;
      font-size: 0.8rem;
    }
  }
</style>