---
import "../styles/prose.css";
import Layout from "./Layout.astro";
import JournalBadges from "../components/JournalBadges.astro";

interface ProseProps {
  title: string;
  description: string;
  headline: string;
  headlineStyle?: "light" | "dark";
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: "website" | "article";
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: object | object[];
}

interface Props extends ProseProps {
  frontmatter?: ProseProps;
}

const {
  title,
  description,
  headline,
  headlineStyle = "dark",
  canonical,
  ogTitle,
  ogDescription,
  ogType,
  ogImage,
  noindex,
  jsonLd,
} = Astro.props.frontmatter ?? Astro.props;
---

<Layout
  title={title}
  description={description}
  headline={headline}
  headlineStyle={headlineStyle}
  canonical={canonical}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  ogType={ogType}
  ogImage={ogImage}
  noindex={noindex}
  jsonLd={jsonLd}
>
  <div class="prose-page">
    <JournalBadges />
    <main class="prose">
      <slot />
    </main>
  </div>
</Layout>

<style>
  .prose-page {
    position: relative;
    width: 100%;
    overflow-x: clip;
  }
</style>
