---
import LayoutSubmit from "./LayoutSubmit.astro";
import { Image } from "astro:assets";
import logoMark from "../assets/logo-vina-gallica.png";
import logoText from "../assets/vina-gallica-text.png";

interface Props {
  title: string;
  active: "details" | "manage" | "submit" | "upgrade";
  lang?: "en" | "fr";
  plan?: "free" | "premium";
}

const { title, active, lang = "en", plan = "free" } = Astro.props;

const isFr = lang === "fr";

const nav = isFr
  ? [
      { key: "details", label: "Détails",  href: "/fr/dashboard" },
      { key: "manage",  label: "Gérer",    href: "/fr/dashboard/manage" },
      { key: "submit",  label: "Soumettre", href: "/fr/dashboard/submit" },
      { key: "upgrade", label: "Abonnement", href: "/fr/dashboard/upgrade" },
    ] as const
  : [
      { key: "details", label: "Details",  href: "/dashboard" },
      { key: "manage",  label: "Manage",   href: "/dashboard/manage" },
      { key: "submit",  label: "Submit",   href: "/dashboard/submit" },
      { key: "upgrade", label: "Upgrade",  href: "/dashboard/upgrade" },
    ] as const;

const logoutHref = isFr ? "/fr/connexion" : "/login";

const langSwitch = isFr
  ? { label: "English", href: "/dashboard" }
  : { label: "Français", href: "/fr/dashboard" };
---

<LayoutSubmit title={title} description="Manage your Vina Gallica business listing.">
  <div class="dash-page">

    <div class="dash-topbar">
      <a href={langSwitch.href} class="dash-topbar-lang">{langSwitch.label}</a>
      <a href={isFr ? "/fr" : "/"} class="dash-logo" aria-label="Vina Gallica - Home Page">
        <Image src={logoMark} alt="Logo Vina Gallica" width={80} height={80} densities={[1, 2]} priority />
        <Image src={logoText} alt="Vina Gallica Directory" width={399} height={69} densities={[1, 2]} priority />
      </a>
      <button
        id="logout-btn"
        class="dash-topbar-logout"
        data-logout-href={logoutHref}
      >{isFr ? "Déconnexion" : "Sign out"}</button>
    </div>

    <nav class="dash-nav" aria-label={isFr ? "Sections du tableau de bord" : "Dashboard sections"}>
      {nav.map(({ key, label, href }) => (
        <a
          href={href}
          class={`dash-nav-link${active === key ? " dash-nav-link--active" : ""}`}
          aria-current={active === key ? "page" : undefined}
        >
          {label}
        </a>
      ))}
    </nav>

    <div class="dash-bar">
      <span class={`dash-bar-plan dash-bar-plan--${plan}`}>
        {plan === "premium"
          ? "Premium"
          : (isFr ? "Gratuit" : "Free")}
      </span>
    </div>

    <main class="dash-main">
      <slot />
    </main>

  </div>
</LayoutSubmit>

<script>
  function initLogout() {
    const btn = document.getElementById("logout-btn") as HTMLButtonElement | null;
    if (!btn) return;
    const href = btn.dataset.logoutHref ?? "/login";
    btn.addEventListener("click", async () => {
      await fetch("/api/auth/logout", { method: "POST" });
      window.location.href = href;
    });
  }
  initLogout();
  document.addEventListener("astro:page-load", initLogout);
</script>

<style>
  .dash-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background-color: var(--color-gold);
  }

  /* ── TOPBAR: logo centered · logout top-right ───────────── */
  .dash-topbar {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: var(--space-md) var(--space-lg);
  }

  .dash-logo {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    text-decoration: none;
    flex-wrap: wrap;
    justify-content: center;
  }

  .dash-topbar-lang {
    position: absolute;
    top: 0;
    left: 0;
    font-family: var(--font-label);
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0.6rem 0.75rem 0.3rem;
    color: var(--color-elegant-black);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 150ms ease;
  }

  .dash-topbar-lang:hover {
    border-bottom-color: var(--color-elegant-black);
  }

  .dash-topbar-logout {
    position: absolute;
    top: 0;
    right: 0;
    font-family: var(--font-label);
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.6rem 0.75rem 0.3rem;
    background-color: var(--color-elegant-black);
    border: none;
    color: var(--color-gold);
    cursor: pointer;
    transition: background-color 150ms ease, color 150ms ease;
  }

  .dash-topbar-logout:hover {
    background-color: firebrick;
    color: var(--color-sand);
  }

  /* ── NAV ────────────────────────────────────────────────── */
  .dash-nav {
    display: flex;
    flex-direction: row;
    justify-content: center;
    background-color: var(--color-elegant-black);
    gap: var(--space-lg);
    padding: 1em 0.5em 0.8em;
  }

  .dash-nav-link {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-decoration: none;
    color: var(--color-sand);
    line-height: 1.1;
  }

  .dash-nav-link--active {
    text-decoration: underline;
    text-underline-offset: 5px;
  }

  /* ── BAR: plan status ───────────────────────────────────── */
  .dash-bar {
    display: flex;
    align-items: baseline;
    justify-content: center;
    background-color: #daa520;
    border-bottom: 1px solid var(--color-elegant-black);
  }

  .dash-bar-plan {
    font-family: var(--font-label);
    font-size: 1.3rem;
    font-weight: 600;
    padding: 0.5rem 0.75rem 0;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .dash-bar-plan--free {
    color: var(--color-elegant-black);
  }

  .dash-bar-plan--premium {
    color: var(--color-wine, #7a1f2e);
  }

  /* ── MAIN ───────────────────────────────────────────────── */
  .dash-main {
    padding: var(--space-lg) var(--space-lg);
    display: block;
    position: relative;
  }

  /* ── RESPONSIVE ─────────────────────────────────────────── */
  @media (max-width: 750px) {
    .dash-logo img:last-child {
      display: none;
    }

    .dash-nav {
      gap: var(--space-md);
      overflow-x: auto;
    }

    .dash-nav-link {
      font-size: 3.5vw;
      white-space: nowrap;
    }

    .dash-main {
      padding: var(--space-lg) var(--space-md);
    }
  }
</style>
